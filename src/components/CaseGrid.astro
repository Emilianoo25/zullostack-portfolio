---
<div class="case-grid">
  <article class="grid-card">
    <div class="card-inner">
      <p class="card-slug">002 // ai_agent</p>
      <h3 class="card-title">Próximo caso</h3>
      <p class="card-desc">Agente de IA en construcción</p>
    </div>
  </article>

  <article class="grid-card grid-card--empty">
    <div class="card-inner card-inner--empty">
      <p class="card-slug-accent">003 // tu_proyecto</p>
      <span class="card-cursor">_</span>
    </div>
  </article>
</div>

<style>
  .case-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-top: 16px;
  }

  .grid-card {
    background: var(--bg-card);
    border: 0.5px solid var(--border-default);
    border-radius: 8px;
    min-height: 180px;
    display: flex;
    align-items: center;
  }

  .grid-card--empty {
    border-style: dashed;
    background: transparent;
    cursor: pointer;
  }

  .card-inner {
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .card-inner--empty {
    width: 100%;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 12px;
  }

  .card-slug {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-tertiary);
    letter-spacing: 0.06em;
  }

  .card-slug-accent {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.06em;
  }

  .card-title {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .card-desc {
    font-size: 13px;
    color: var(--text-tertiary);
  }

  .card-cursor {
    font-family: var(--font-mono);
    font-size: 24px;
    color: var(--text-tertiary);
    display: block;
  }

  @media (max-width: 480px) {
    .case-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
