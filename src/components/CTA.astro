---
const calUrl = import.meta.env.PUBLIC_CAL_URL ?? 'https://cal.com/zullostack/15min';
---
<section class="cta-section" aria-labelledby="cta-title">
  <div class="cta-inner">
    <div class="circles-deco" aria-hidden="true">
      <div class="circle circle-outer"></div>
      <div class="circle circle-inner"></div>
    </div>

    <div class="content">
      <h2 id="cta-title" class="cta-title">¿Tu negocio pierde plata online?</h2>
      <p class="cta-sub">
        15 minutos. Te digo si puedo ayudarte o no. Sin venderte humo.
      </p>
      <a href={calUrl} class="cta-btn" target="_blank" rel="noopener noreferrer">
        → agendar ahora
      </a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 80px 24px;
    position: relative;
    z-index: 1;
    overflow: hidden;
  }

  .cta-inner {
    max-width: 1080px;
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  .circles-deco {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .circle {
    position: absolute;
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .circle-outer {
    width: 600px;
    height: 600px;
    border: 0.5px solid rgba(74, 222, 128, 0.04);
  }

  .circle-inner {
    width: 400px;
    height: 400px;
    border: 0.5px solid rgba(74, 222, 128, 0.06);
  }

  .content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .cta-title {
    font-family: var(--font-sans);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: -0.04em;
    line-height: 1.1;
    max-width: 520px;
  }

  .cta-sub {
    font-size: 16px;
    color: var(--text-secondary);
    max-width: 420px;
    line-height: 1.6;
  }

  .cta-btn {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    background: var(--accent);
    color: #000;
    text-decoration: none;
    padding: 13px 28px;
    border-radius: 6px;
    margin-top: 8px;
    transition: opacity 0.15s;
    display: inline-block;
  }

  .cta-btn:hover {
    opacity: 0.88;
  }
</style>
