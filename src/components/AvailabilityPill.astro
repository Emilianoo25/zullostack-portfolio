<div class="pill">
  <span class="dot pulse-dot" aria-hidden="true"></span>
  <span>disponible para nuevos proyectos</span>
</div>

<style>
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent-glow);
    border: 0.5px solid var(--border-accent);
    border-radius: 100px;
    padding: 6px 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.02em;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }
</style>
