---
import AvailabilityPill from './AvailabilityPill.astro';

const calUrl = import.meta.env.PUBLIC_CAL_URL ?? 'https://cal.com/zullostack/15min';
---
<section class="hero">
  <div class="hero-inner">
    <AvailabilityPill />

    <h1 class="headline">
      Webs que <em>venden</em>.<br />
      Agentes que <em>trabajan</em> solos.
    </h1>

    <p class="sub">
      Soy Emi. Construyo sitios y automatizaciones de IA para PyMEs en Buenos Aires
      que están dejando plata sobre la mesa.
    </p>

    <div class="ctas">
      <a href={calUrl} class="cta-primary" target="_blank" rel="noopener noreferrer">
        agendá una llamada →
      </a>
      <a href="#work" class="cta-secondary">
        ver casos de estudio
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 96px 24px 80px;
    position: relative;
    z-index: 1;
  }

  .hero-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 28px;
    align-items: flex-start;
  }

  .headline {
    font-family: var(--font-sans);
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    max-width: 640px;
  }

  .headline em {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--accent);
    letter-spacing: -0.02em;
  }

  .sub {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 540px;
    line-height: 1.6;
  }

  .ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .cta-primary {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    background: var(--accent);
    color: #000;
    text-decoration: none;
    padding: 11px 22px;
    border-radius: 6px;
    transition: opacity 0.15s;
  }

  .cta-primary:hover {
    opacity: 0.88;
  }

  .cta-secondary {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 11px 22px;
    border-radius: 6px;
    border: 0.5px solid var(--border-default);
    transition: border-color 0.15s, color 0.15s;
  }

  .cta-secondary:hover {
    border-color: var(--border-strong);
    color: var(--text-primary);
  }
</style>
