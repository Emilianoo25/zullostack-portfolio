---
interface Props {
  titleTop: string;
  titleBottom: string;
  imageSrc: string;
  imageAlt: string;
}
const { titleTop, titleBottom, imageSrc, imageAlt } = Astro.props;
---

<section class="hs-section">
  <div class="hs-sticky">
    <div class="hs-content">
      <h2 class="hs-title hs-title--top" aria-hidden="true">{titleTop}</h2>
      <div class="hs-card">
        <img src={imageSrc} alt={imageAlt} class="hs-img" />
      </div>
      <h2 class="hs-title hs-title--bottom" aria-hidden="true">{titleBottom}</h2>
    </div>
    <p class="hs-hint">scroll ↓</p>
  </div>
</section>

<style>
  .hs-section {
    position: relative;
    width: 100%;
    height: 250vh;
    overflow: clip;
  }

  .hs-sticky {
    position: sticky;
    top: 0;
    height: 100svh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hs-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
  }

  .hs-title {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(3.2rem, 11vw, 7.5rem);
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    text-transform: uppercase;
    will-change: transform, opacity;
    user-select: none;
    text-align: center;
  }

  .hs-card {
    width: min(52vw, 220px);
    aspect-ratio: 3 / 4;
    border-radius: 10px;
    overflow: hidden;
    will-change: transform;
    border: 0.5px solid var(--border-default);
    flex-shrink: 0;
  }

  @media (min-width: 640px) {
    .hs-card {
      width: min(28vw, 260px);
    }
  }

  .hs-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .hs-hint {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-tertiary);
    letter-spacing: 0.06em;
    white-space: nowrap;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const section  = document.querySelector('.hs-section') as HTMLElement;
  if (section) {
    const card      = section.querySelector('.hs-card')         as HTMLElement;
    const titleTop  = section.querySelector('.hs-title--top')   as HTMLElement;
    const titleBot  = section.querySelector('.hs-title--bottom') as HTMLElement;
    const hint      = section.querySelector('.hs-hint')         as HTMLElement;

    // Entry: todo aparece suavemente
    gsap.timeline({ delay: 0.1 })
      .from(card,     { opacity: 0, scale: 0.9, duration: 0.9, ease: 'power3.out' })
      .from(titleTop, { opacity: 0, y:  28, duration: 0.75, ease: 'expo.out' }, 0.25)
      .from(titleBot, { opacity: 0, y: -28, duration: 0.75, ease: 'expo.out' }, 0.35)
      .from(hint,     { opacity: 0, duration: 0.6 }, 0.7);

    // Scroll: nombre izq, apellido der, foto zoom suave
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: 'top top',
        end:   'bottom bottom',
        scrub: 0.6,
        invalidateOnRefresh: true,
      },
    });

    tl
      .to(titleTop, {
        x: () => -(window.innerWidth * 0.55),
        opacity: 0,
        ease: 'power2.inOut',
        duration: 0.55,
      }, 0)
      .to(titleBot, {
        x: () => window.innerWidth * 0.55,
        opacity: 0,
        ease: 'power2.inOut',
        duration: 0.55,
      }, 0)
      .to(card, {
        scale: 1.12,
        ease: 'power1.inOut',
        duration: 0.55,
      }, 0)
      .to(hint, { opacity: 0, duration: 0.15 }, 0)
      // al final la card también se va suavemente
      .to(card, {
        opacity: 0,
        y: -30,
        ease: 'power2.in',
        duration: 0.4,
      }, 0.6);

    ScrollTrigger.refresh();
  }
</script>
