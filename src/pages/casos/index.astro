---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const casos = await getCollection('casos');
const sorted = casos.sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);
---
<Base
  title="Casos de estudio — ZulloStack"
  description="Proyectos reales de desarrollo web y automatización de IA para PyMEs en Buenos Aires."
>
  <div class="page-wrap">
    <div class="page-inner">
      <header class="page-header">
        <p class="eyebrow">— SELECTED WORK</p>
        <h1 class="page-title">Casos de estudio.</h1>
      </header>

      <div class="cases-grid">
        {sorted.map((caso) => (
          <article class="case-card">
            <a href={`/casos/${caso.id.replace(/\.mdx?$/, '')}`} class="case-link">
              <div class="case-meta">
                <span class="badge-category">{caso.data.category}</span>
                <span class="badge-year">{caso.data.year}</span>
              </div>
              <h2 class="case-title">{caso.data.title}</h2>
              <p class="case-result">{caso.data.result}</p>
              <div class="case-tags">
                {caso.data.tags.slice(0, 3).map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <span class="case-arrow">→</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </div>
</Base>

<style>
  .page-wrap {
    padding: 64px 24px 80px;
    position: relative;
    z-index: 1;
  }

  .page-inner {
    max-width: 1080px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: 48px;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 1px;
    margin-bottom: 14px;
  }

  .page-title {
    font-family: var(--font-sans);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: -0.04em;
    line-height: 1.05;
  }

  .cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .case-card {
    background: var(--bg-card);
    border: 0.5px solid var(--border-default);
    border-radius: 12px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.15s;
  }

  .case-card:hover {
    border-color: var(--border-strong);
  }

  .case-link {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 28px;
    text-decoration: none;
    color: inherit;
  }

  .case-meta {
    display: flex;
    gap: 8px;
  }

  .badge-category,
  .badge-year {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 3px 10px;
    border-radius: 100px;
    letter-spacing: 0.04em;
  }

  .badge-category {
    background: rgba(74, 222, 128, 0.1);
    color: var(--accent);
    border: 0.5px solid var(--border-accent);
  }

  .badge-year {
    color: var(--text-tertiary);
    border: 0.5px solid var(--border-default);
  }

  .case-title {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: -0.03em;
  }

  .case-result {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .case-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-tertiary);
    border: 0.5px solid var(--border-subtle);
    border-radius: 4px;
    padding: 2px 8px;
  }

  .case-arrow {
    font-family: var(--font-mono);
    font-size: 16px;
    color: var(--accent);
    margin-top: auto;
    transition: transform 0.15s;
    display: inline-block;
  }

  .case-link:hover .case-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .cases-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
